rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function isOwner(uid) {
      return request.auth != null && request.auth.uid == uid;
    }

    function validPlayerName() {
      return request.resource.data.name is string
        && request.resource.data.name.size() >= 3
        && request.resource.data.name.size() <= 20;
    }

    // Player profiles: public read, owner-only write.
    match /players/{uid} {
      allow read: if true;
      allow write: if isOwner(uid) && validPlayerName();
    }

    // Per-level best times: one doc per player per level.
    // Times only ever improve (decrease); a 5s floor rejects garbage.
    match /levels/{level}/scores/{uid} {
      allow read: if true;
      allow create: if isOwner(uid)
        && validPlayerName()
        && request.resource.data.timeMs is number
        && request.resource.data.timeMs > 5000;
      allow update: if isOwner(uid)
        && validPlayerName()
        && request.resource.data.timeMs is number
        && request.resource.data.timeMs > 5000
        && request.resource.data.timeMs <= resource.data.timeMs;
    }

    // Overall standing: highest cleared level (monotonic), total best time.
    match /overall/{uid} {
      allow read: if true;
      allow create: if isOwner(uid)
        && validPlayerName()
        && request.resource.data.highestLevel is int
        && request.resource.data.highestLevel >= 1
        && request.resource.data.highestLevel <= 100
        && request.resource.data.totalTimeMs is number
        && request.resource.data.totalTimeMs >= 0;
      allow update: if isOwner(uid)
        && validPlayerName()
        && request.resource.data.highestLevel is int
        && request.resource.data.highestLevel >= resource.data.highestLevel
        && request.resource.data.highestLevel <= 100
        && request.resource.data.totalTimeMs is number
        && request.resource.data.totalTimeMs >= 0;
    }
  }
}
